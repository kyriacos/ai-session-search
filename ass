#!/usr/bin/env bash
# ass — AI Session Search
#
# Fuzzy-search chat history across Claude Code and Cursor.
# Both tools are optional — the script skips any source that isn't installed.
#
# Keys
#   Enter  print identifier to stdout
#   F1     Claude Code sessions only
#   F2     Cursor sessions only
#   F3     all sessions
#   F4     toggle date sort (↓ newest first / ↑ oldest first)
#   F5     resume selected session
#   F6     toggle Cursor resume target (gui cursor / cli agent)
#   F7     open project/branch filter prompt
#   F8     clear project/branch filter
#   F10    toggle subagent sessions (hidden by default)
#   Ctrl-C cancel
#
# Output on Enter
#   Claude  →  /path/to/session.jsonl
#   Cursor  →  cursor:<composerId>:<workspacePath>
#
# Environment overrides
#   CLAUDE_PROJECTS_DIR      override ~/.claude/projects
#   CURSOR_GLOBALSTATE_DB    override platform-default Cursor DB path
#   CURSOR_LAUNCH_MODE       Cursor resume target: gui (default) or agent

set -uo pipefail

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<'EOF'
ass — AI Session Search

Fuzzy-search chat history across Claude Code and Cursor from the terminal.

USAGE
  ass                  open interactive session picker
  ass --help           show this help

KEYS (in picker)
  Enter                print session identifier to stdout
  F1                   Claude Code sessions only
  F2                   Cursor sessions only
  F3                   all sessions (reset source filter)
  F4                   toggle date sort (↓ newest first / ↑ oldest first)
  F5                   resume selected session
  F6                   toggle Cursor resume target (gui / agent)
  F7                   filter by project/branch (prompt)
  F8                   clear project/branch filter
  F10                  toggle subagent sessions (hidden by default)
  Ctrl-C               cancel

RESUME BEHAVIOUR (F5)
  Claude Code  →  claude --resume <uuid>
  Cursor gui   →  cursor --reuse-window <workspace-path>
  Cursor agent →  agent --resume <composerId> --workspace <workspace-path>

OUTPUT (on Enter)
  Claude  →  /path/to/session.jsonl
  Cursor  →  cursor:<composerId>:<workspacePath>

ENVIRONMENT
  CLAUDE_PROJECTS_DIR     override ~/.claude/projects
  CURSOR_GLOBALSTATE_DB   override platform-default Cursor DB path
  CURSOR_LAUNCH_MODE      Cursor resume target: gui (default) or agent

REQUIREMENTS
  fzf >= 0.45   brew install fzf
  bat           brew install bat
  python3       ships with macOS / most Linux

MORE INFO
  https://github.com/kyriacos/ai-session-search
EOF
  exit 0
fi

SELF="$(realpath "$0" 2>/dev/null || echo "$0")"
CLAUDE_DIR="${CLAUDE_PROJECTS_DIR:-$HOME/.claude/projects}"

case "$(uname)" in
  Darwin) _cursor_default="$HOME/Library/Application Support/Cursor/User/globalStorage/state.vscdb" ;;
  Linux)  _cursor_default="$HOME/.config/Cursor/User/globalStorage/state.vscdb" ;;
  *)      _cursor_default="" ;;
esac
CURSOR_DB="${CURSOR_GLOBALSTATE_DB:-$_cursor_default}"

# ── helpers ───────────────────────────────────────────────────────────────────

_header() {
  local filter="${1:-all}" sort="${2:-desc}" subagents="${3:-no}" cursor_launch="${4:-gui}" proj_filter="${5:-}"
  local f1 f2 f3 f4 f6 f7f8 f10
  case "$filter" in
    claude) f1=$'\033[1;36mF1:claude\033[0m' f2=$'F2:cursor' f3=$'F3:all' ;;
    cursor) f1=$'F1:claude' f2=$'\033[1;33mF2:cursor\033[0m' f3=$'F3:all' ;;
    *)      f1=$'F1:claude' f2=$'F2:cursor' f3=$'\033[1mF3:all\033[0m' ;;
  esac
  if [[ "$sort" == "asc" ]]; then
    f4=$'\033[1;32mF4:date↑\033[0m'
  else
    f4=$'\033[1;32mF4:date↓\033[0m'
  fi
  if [[ "$cursor_launch" == "agent" ]]; then
    f6=$'\033[1;33mF6:agent\033[0m'
  else
    f6=$'\033[2mF6:gui\033[0m'
  fi
  if [[ -n "$proj_filter" ]]; then
    local shown="$proj_filter"
    [[ ${#shown} -gt 24 ]] && shown="${shown:0:23}…"
    f7f8=$'\033[1;32mfilter:'"$shown"$'\033[0m '"F8:clear"
  else
    f7f8=$'F7:filter  F8:clear'
  fi
  if [[ "$subagents" == "yes" ]]; then
    f10=$'\033[1;32mF10:+sub\033[0m'
  else
    f10=$'\033[2mF10:+sub\033[0m'
  fi
  echo "  AI Session Search  ${f1}  ${f2}  ${f3}  ${f4}  ${f6}  ${f10}  |  ${f7f8}  |  F5:resume  |  Ctrl-C:cancel"
}

# ── header mode ───────────────────────────────────────────────────────────────

if [[ "${1:-}" == "--header" ]]; then
  _header "${2:-all}" "${3:-desc}" "${4:-no}" "${5:-gui}" "${ASS_PROJ_FILTER:-}"
  exit 0
fi

# ── project filter prompt ─────────────────────────────────────────────────────

if [[ "${1:-}" == "--prompt-filter" ]]; then
  outfile="${2:?}"
  current=""
  [[ -s "$outfile" ]] && current="$(cat "$outfile")"
  printf '%s\n' "Current: ${current:-(none)}" "Enter project or branch name. Empty line clears."
  if ! IFS= read -r -p 'Filter> ' selected </dev/tty; then
    exit 0
  fi
  printf '%s' "$selected" > "$outfile"
  exit 0
fi

# ── preview mode ──────────────────────────────────────────────────────────────

if [[ "${1:-}" == "--preview" ]]; then
  identifier="$2"

  python3 - "$identifier" "$CURSOR_DB" <<'PYEOF'
import sys, json, sqlite3, os, re, subprocess, shutil

identifier = sys.argv[1]
cursor_db  = sys.argv[2]

RESET   = "\033[0m"
DIM     = "\033[2m"
BLUE    = "\033[1;34m"
MAGENTA = "\033[1;35m"

BAT = shutil.which("bat")

LANG_ALIASES = {
    "js": "JavaScript", "ts": "TypeScript", "py": "Python",
    "sh": "Bash", "bash": "Bash", "zsh": "Bash", "rb": "Ruby",
    "rs": "Rust", "go": "Go", "yml": "YAML", "yaml": "YAML",
    "toml": "TOML", "tf": "Terraform",
}


def highlight_code(code: str, lang: str) -> str:
    if not BAT:
        return code
    lang = LANG_ALIASES.get(lang.strip(), lang.strip()) or "text"
    try:
        r = subprocess.run(
            [BAT, "--language", lang, "--color=always", "--style=plain", "--paging=never"],
            input=code.encode(), capture_output=True, timeout=3,
        )
        if r.returncode == 0:
            return r.stdout.decode()
    except Exception:
        pass
    return code


def render_text(text: str) -> str:
    out, pos = [], 0
    for m in re.finditer(r'```(\w*)\n(.*?)```', text, re.DOTALL):
        if text[pos:m.start()]:
            out.append(text[pos:m.start()])
        out.append(f"\n{highlight_code(m.group(2), m.group(1))}\n")
        pos = m.end()
    out.append(text[pos:])
    return "".join(out)


def print_turn(role: str, text: str) -> None:
    if not text.strip():
        return
    label = f"[{BLUE}YOU{RESET}]" if role == "user" else f"[{MAGENTA} AI{RESET}]"
    indented = ("\n" + " " * 7).join(render_text(text.strip()).split("\n"))
    print(f"{label}  {indented}\n")


# ── Claude Code ───────────────────────────────────────────────────────────────
if not identifier.startswith("cursor:"):
    try:
        with open(identifier, errors="replace") as f:
            count = 0
            for line in f:
                if not line.strip():
                    continue
                try:
                    obj = json.loads(line)
                    msg = obj.get("message")
                    if not isinstance(msg, dict):
                        continue
                    role = msg.get("role", "")
                    if role not in ("user", "assistant"):
                        continue
                    content = msg.get("content", "")
                    if isinstance(content, list):
                        if role == "user":
                            continue
                        parts = [b.get("text", "") for b in content
                                 if isinstance(b, dict) and b.get("type") == "text"]
                        content = "\n".join(parts)
                    if not isinstance(content, str) or not content.strip():
                        continue
                    print_turn(role, content[:1200])
                    count += 1
                    if count >= 16:
                        break
                except Exception:
                    continue
    except Exception as e:
        print(f"Error reading session: {e}")
    sys.exit(0)

# ── Cursor ────────────────────────────────────────────────────────────────────
parts = identifier.split(":", 2)
composer_id = parts[1] if len(parts) >= 2 else ""
workspace   = parts[2] if len(parts) >= 3 else ""

if workspace:
    print(f"{DIM}Project: {workspace}{RESET}\n")

if not cursor_db or not os.path.exists(cursor_db):
    print("Cursor session store not found.")
    sys.exit(0)

try:
    conn = sqlite3.connect(f"file:{cursor_db}?mode=ro", uri=True)
    row  = conn.execute(
        "SELECT value FROM cursorDiskKV WHERE key = ?",
        (f"composerData:{composer_id}",)
    ).fetchone()
    if not row:
        print("No data for this composer.")
        sys.exit(0)

    data     = json.loads(row[0])
    subtitle = data.get("subtitle", "")
    if subtitle:
        print(f"{DIM}Files: {subtitle}{RESET}\n")

    count = 0
    for h in data.get("fullConversationHeadersOnly", []):
        if count >= 14:
            break
        btype = h.get("type")
        if btype not in (1, 2):
            continue
        bid = h.get("bubbleId")
        if not bid:
            continue
        br = conn.execute(
            "SELECT value FROM cursorDiskKV WHERE key = ?",
            (f"bubbleId:{composer_id}:{bid}",)
        ).fetchone()
        if not br or br[0] is None:
            continue
        text = json.loads(br[0]).get("text", "").strip()
        if not text:
            continue
        print_turn("user" if btype == 1 else "assistant", text[:1200])
        count += 1
except Exception as e:
    print(f"Error reading Cursor session: {e}")
PYEOF
  exit 0
fi

# ── list mode ─────────────────────────────────────────────────────────────────

if [[ "${1:-}" == "--list" ]]; then
  source_filter="${2:-all}"
  sort_order="${3:-desc}"
  subagents="${4:-no}"
  proj_filter="${ASS_PROJ_FILTER:-}"

  python3 - "$CLAUDE_DIR" "$CURSOR_DB" "$source_filter" "$HOME" "$sort_order" "$subagents" "$proj_filter" <<'PYEOF'
import sys, json, sqlite3, os, pathlib, shutil
from datetime import datetime

claude_dir       = pathlib.Path(sys.argv[1])
cursor_db        = sys.argv[2]
source_filter    = sys.argv[3]
home             = sys.argv[4]
sort_order       = sys.argv[5] if len(sys.argv) > 5 else "desc"
include_subagents = sys.argv[6] if len(sys.argv) > 6 else "no"
proj_filter      = sys.argv[7] if len(sys.argv) > 7 else ""
proj_filter_l    = proj_filter.lower()

RESET  = "\033[0m"
CYAN   = "\033[36m"
YELLOW = "\033[33m"
GREEN  = "\033[32m"
DIM    = "\033[2m"

DATE_W = 16
SRC_W  = 6
PROJ_W = 36

def fixed(text, width):
    """Truncate/pad to exact visible width before applying ANSI codes."""
    if len(text) > width:
        return text[:width - 1] + "…"
    return text.ljust(width)

def matches_proj_filter(project: str, branch: str = "", path: str = "") -> bool:
    if not proj_filter_l:
        return True
    haystack = f"{project} {branch} {path}".lower()
    return proj_filter_l in haystack

# Claude encodes paths by replacing / and . with -
encoded_home = home.replace("/", "-").replace(".", "-")

def project_label(folder_name: str) -> str:
    if folder_name.startswith(encoded_home):
        return folder_name[len(encoded_home):].lstrip("-") or folder_name
    return folder_name

rows = []

# ── Claude Code ───────────────────────────────────────────────────────────────
if source_filter in ("all", "claude") and claude_dir.exists():
    for f in claude_dir.rglob("*.jsonl"):
        is_subagent = f.parent.name == "subagents"
        if is_subagent and include_subagents != "yes":
            continue
        project   = project_label(f.parent.name if not is_subagent else f.parent.parent.name)
        first_msg = ""
        branch    = ""
        try:
            with open(f, errors="replace") as fh:
                for line in fh:
                    if not line.strip():
                        continue
                    try:
                        obj = json.loads(line)
                        if not branch:
                            branch = obj.get("gitBranch", "")
                        msg = obj.get("message")
                        if not isinstance(msg, dict) or msg.get("role") != "user":
                            continue
                        content = msg.get("content", "")
                        if isinstance(content, list):
                            continue
                        if isinstance(content, str) and content.strip():
                            first_msg = content.strip()[:120].replace("\n", " ").replace("\t", " ")
                            break
                    except Exception:
                        continue
        except Exception:
            pass

        if not first_msg:
            continue

        if not matches_proj_filter(project, branch):
            continue

        mtime     = f.stat().st_mtime
        date_s    = datetime.fromtimestamp(mtime).strftime("%Y-%m-%d %H:%M")
        label     = project + (f" [{branch}]" if branch else "")
        if is_subagent:
            label = "↳ " + label
        display   = (f"{DIM}{fixed(date_s, DATE_W)}{RESET}  "
                     f"{CYAN}{fixed('claude', SRC_W)}{RESET}  "
                     f"{GREEN}{fixed(label, PROJ_W)}{RESET}  "
                     f"{first_msg}")
        search = " ".join(p for p in (project, branch, first_msg) if p).replace("\t", " ")
        rows.append((mtime, f"{search}\t{display}\t{f}"))

# ── Cursor ────────────────────────────────────────────────────────────────────
if source_filter in ("all", "cursor") and cursor_db and os.path.exists(cursor_db):
    try:
        conn = sqlite3.connect(f"file:{cursor_db}?mode=ro", uri=True)
        hrow = conn.execute(
            "SELECT value FROM ItemTable WHERE key = 'composer.composerHeaders'"
        ).fetchone()
        if hrow:
            for c in json.loads(hrow[0]).get("allComposers", []):
                cid = c.get("composerId")
                if not cid:
                    continue
                cr = conn.execute(
                    "SELECT value FROM cursorDiskKV WHERE key = ?",
                    (f"composerData:{cid}",)
                ).fetchone()
                if not cr or cr[0] is None:
                    continue
                d = json.loads(cr[0])

                summary = (d.get("subtitle") or d.get("text") or "").strip()
                if not summary:
                    continue
                summary = summary[:120].replace("\n", " ").replace("\t", " ")

                ws      = d.get("workspaceIdentifier") or {}
                uri     = ws.get("uri") or {}
                path    = uri.get("fsPath", "") or ""
                project = os.path.basename(path) or "unknown"

                if not matches_proj_filter(project, path=path):
                    continue

                ts    = d.get("createdAt") or c.get("createdAt") or 0
                mtime = ts / 1000 if ts else 0
                date_s = datetime.fromtimestamp(mtime).strftime("%Y-%m-%d %H:%M") if mtime else "unknown"

                display = (f"{DIM}{fixed(date_s, DATE_W)}{RESET}  "
                           f"{YELLOW}{fixed('cursor', SRC_W)}{RESET}  "
                           f"{GREEN}{fixed(project, PROJ_W)}{RESET}  "
                           f"{summary}")
                search = " ".join(p for p in (project, path, summary) if p).replace("\t", " ")
                rows.append((mtime, f"{search}\t{display}\tcursor:{cid}:{path}"))
    except Exception:
        pass

if not rows:
    print("  (no sessions found)", flush=True)

rows.sort(key=lambda x: x[0], reverse=(sort_order == "desc"))
for _, line in rows:
    print(line)
PYEOF
  exit 0
fi

# ── resume mode ───────────────────────────────────────────────────────────────

if [[ "${1:-}" == "--resume" ]]; then
  identifier="$2"
  cursor_launch="${3:-gui}"
  if [[ "$identifier" == cursor:* ]]; then
    IFS=: read -r _ _cid workspace_path <<< "$identifier"
    if [[ "$cursor_launch" == "agent" ]]; then
      if ! command -v agent &>/dev/null; then
        echo "ass: 'agent' not found on PATH" >&2
        exit 1
      fi
      if [[ -n "${workspace_path:-}" ]]; then
        exec agent --resume "$_cid" --workspace "$workspace_path"
      else
        exec agent --resume "$_cid"
      fi
    else
      if ! command -v cursor &>/dev/null; then
        echo "ass: 'cursor' not found on PATH" >&2
        exit 1
      fi
      cursor --reuse-window "${workspace_path:-}"
    fi
  else
    if ! command -v claude &>/dev/null; then
      echo "ass: 'claude' not found on PATH" >&2
      exit 1
    fi
    exec claude --resume "$(basename "$identifier" .jsonl)"
  fi
  exit 0
fi

# ── fzf picker ────────────────────────────────────────────────────────────────
# F5 signals resume via become(echo RESUME:{2}) so that after fzf exits the
# main shell — which owns the real TTY — can hand off to claude or cursor.
# Each row is: plain-search TAB fixed-width-display TAB identifier
# --with-nth=2 shows only the display column; --nth=1 searches plain text only.

_filter_file=$(mktemp)
_sort_file=$(mktemp)
_subagents_file=$(mktemp)
_cursor_launch_file=$(mktemp)
_proj_filter_file=$(mktemp)
echo "all"  > "$_filter_file"
echo "desc" > "$_sort_file"
echo "no"   > "$_subagents_file"
: > "$_proj_filter_file"
case "${CURSOR_LAUNCH_MODE:-gui}" in
  agent) echo "agent" > "$_cursor_launch_file" ;;
  *)     echo "gui"   > "$_cursor_launch_file" ;;
esac
trap "rm -f \"$_filter_file\" \"$_sort_file\" \"$_subagents_file\" \"$_cursor_launch_file\" \"$_proj_filter_file\"" EXIT

_LIST_RELOAD="ASS_PROJ_FILTER=\$(cat \"$_proj_filter_file\") \"$SELF\" --list \$(cat \"$_filter_file\") \$(cat \"$_sort_file\") \$(cat \"$_subagents_file\")"
_HEADER_XFORM="ASS_PROJ_FILTER=\$(cat \"$_proj_filter_file\") \"$SELF\" --header \$(cat \"$_filter_file\") \$(cat \"$_sort_file\") \$(cat \"$_subagents_file\") \$(cat \"$_cursor_launch_file\")"

result=$(
  ASS_PROJ_FILTER="$(cat "$_proj_filter_file")" "$SELF" --list all desc no | fzf \
    --ansi \
    --exact \
    --no-sort \
    --delimiter=$'\t' \
    --with-nth=2 \
    --nth=1 \
    --preview="\"$SELF\" --preview {3}" \
    --preview-window='right:55%:wrap' \
    --height=90% \
    --layout=reverse \
    --header="$(ASS_PROJ_FILTER="$(cat "$_proj_filter_file")" "$SELF" --header all desc no "$(cat "$_cursor_launch_file")")" \
    --color='header:italic,hl:yellow,hl+:yellow' \
    --bind="f1:execute-silent(echo claude > \"$_filter_file\")+reload($_LIST_RELOAD)+transform-header($_HEADER_XFORM)" \
    --bind="f2:execute-silent(echo cursor > \"$_filter_file\")+reload($_LIST_RELOAD)+transform-header($_HEADER_XFORM)" \
    --bind="f3:execute-silent(echo all > \"$_filter_file\")+reload($_LIST_RELOAD)+transform-header($_HEADER_XFORM)" \
    --bind="f4:execute-silent(s=\$(cat \"$_sort_file\"); [ \"\$s\" = desc ] && echo asc > \"$_sort_file\" || echo desc > \"$_sort_file\")+reload($_LIST_RELOAD)+transform-header($_HEADER_XFORM)" \
    --bind="f6:execute-silent(m=\$(cat \"$_cursor_launch_file\"); [ \"\$m\" = gui ] && echo agent > \"$_cursor_launch_file\" || echo gui > \"$_cursor_launch_file\")+transform-header($_HEADER_XFORM)" \
    --bind="f7:execute(\"$SELF\" --prompt-filter \"$_proj_filter_file\")+change-query()+reload($_LIST_RELOAD)+transform-header($_HEADER_XFORM)" \
    --bind="f8:execute-silent(: > \"$_proj_filter_file\")+change-query()+reload($_LIST_RELOAD)+transform-header($_HEADER_XFORM)" \
    --bind="f10:execute-silent(s=\$(cat \"$_subagents_file\"); [ \"\$s\" = no ] && echo yes > \"$_subagents_file\" || echo no > \"$_subagents_file\")+reload($_LIST_RELOAD)+transform-header($_HEADER_XFORM)" \
    --bind='f5:become(echo RESUME:{3})'
) || exit 0

[[ -z "$result" ]] && exit 0

if [[ "$result" == RESUME:* ]]; then
  "$SELF" --resume "${result#RESUME:}" "$(cat "$_cursor_launch_file")"
else
  echo "$result" | cut -f3
fi
